// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run the `open default settings` command
// from the command palette or from `Zed` application menu.
{
  "project_panel": {
    "dock": "left"
  },
  "outline_panel": {
    "dock": "right"
  },
  "git_panel": {
    "dock": "left"
  },
  "icon_theme": "Catppuccin Frappé",
  "agent_servers": {
    "github-copilot-cli": {
      "type": "registry"
    },
    "cursor": {
      "type": "registry"
    },
    "claude-acp": {
      "favorite_config_option_values": {
        "model": [
          "opus[1m]"
        ]
      },
      "type": "registry",
      "default_model": "opus[1m]",
      "default_config_options": {
        "mode": "bypassPermissions",
        "model": "opus[1m]"
      }
    }
  },
  "language_models": {
    "openai_compatible": {
      "Inference Hub": {
        "api_url": "https://inference-api.nvidia.com",
        "available_models": [
          {
            "name": "aws/anthropic/claude-opus-4-5",
            "max_tokens": 32000,
            "max_output_tokens": 31000,
            "max_completion_tokens": 63000,
            "capabilities": {
              "tools": true,
              "images": false,
              "parallel_tool_calls": false,
              "prompt_cache_key": false
            }
          },
          {
            "name": "gcp/google/gemini-3-pro",
            "max_tokens": 32000,
            "max_output_tokens": 31000,
            "max_completion_tokens": 63000,
            "capabilities": {
              "tools": true,
              "images": false,
              "parallel_tool_calls": false,
              "prompt_cache_key": false
            }
          }
        ]
      }
    }
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },
  "ssh_connections": [
    {
      "host": "computelab-session",
      "args": [],
      "projects": [
        {
          "paths": [
            "/home/scratch.ishovkun_gpu"
          ]
        },
        {
          "paths": [
            "/home/scratch.ishovkun_gpu/code/TensorRT-LLM"
          ]
        },
        {
          "paths": [
            "/home/scratch.ishovkun_gpu/code/flashinfer-dev"
          ]
        },
        {
          "paths": [
            "/home/scratch.ishovkun_gpu/code/selective_state"
          ]
        },
        {
          "paths": [
            "/home/scratch.ishovkun_gpu/code/sglang"
          ]
        }
      ]
    }
  ],
  "agent": {
    "dock": "right",
    "commit_message_model": {
      "provider": "copilot_chat",
      "model": "claude-sonnet-4.6"
    },
    "tool_permissions": {
      "default": "allow"
    },
    "default_profile": "write",
    "default_model": {
      "effort": "high",
      "enable_thinking": true,
      "provider": "copilot_chat",
      "model": "claude-opus-4.6"
    },
    "model_parameters": []
  },
  "use_system_path_prompts": false,
  "use_system_prompts": false,
  "agent_buffer_font_size": 13.0,
  "agent_ui_font_size": 18.0,
  "inlay_hints": {
    "enabled": false,
    "show_value_hints": true,
    "show_type_hints": true,
    "show_parameter_hints": true,
    "show_other_hints": true,
    "show_background": false,
    "edit_debounce_ms": 700,
    "scroll_debounce_ms": 50,
    "toggle_on_modifiers_press": {
      "control": false,
      "alt": false,
      "shift": false,
      "platform": false,
      "function": false
    }
  },
  "base_keymap": "Emacs",
  "collaboration_panel": {
    "dock": "right"
  },
  // "agent": {
  //   "always_allow_tool_actions": true,
  //   "play_sound_when_agent_done": true,
