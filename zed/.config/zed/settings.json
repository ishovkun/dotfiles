  //   "default_profile": "ask",
  //   "inline_assistant_model": {
  //     "provider": "zed.dev",
  //     "model": "claude-sonnet-4-thinking-latest"
  //   },
  //   "model_parameters": [],
  //   "default_model": {
  //     "provider": "copilot_chat",
  //     "model": "claude-sonnet-4"
  //   }
  // },
  "edit_predictions": {
    "disabled_globs": [],
    "provider": "copilot",
    "mode": "subtle"
  },
  "tab_bar": {
    "show": true
  },
  "which_key": {
    // Whether to show the which-key popup when holding down key combinations.
    "enabled": true,
    // Delay in milliseconds before showing the which-key popup.
    "delay_ms": 200,
  },
  "theme": "Catppuccin Frappé",
  "cursor_blink": false,
  "vim_mode": true,
  "ui_font_size": 14,
  "buffer_font_size": 13,
  "buffer_font_family": "Iosevka Nerd Font",
  "buffer_line_height": "comfortable",
  "scrollbar": {
    "axes": {
      "horizontal": false
    }
  },
  "toolbar": {
    //   // set these two to false to hide the toolbar
    "breadcrumbs": true,
    "selections_menu": false,
    "code_actions": true
    //   // "quick_actions": true
  },
  "active_pane_modifiers": {
    "border_size": 1.0,
    "inactive_opacity": 1.0
  },
  // "search": {
  //   // Whether to show the project search button in the status bar.
  //   "button": true,
  //   "whole_word": false,
  //   "case_sensitive": false,
  //   "include_ignored": false,
  //   "regex": false
  // },
  "use_smartcase_search": true,
  "vim": {
    "default_mode": "normal",
    "toggle_relative_line_numbers": true,
    "use_system_clipboard": "on_yank",
    "use_smartcase_find": true,
    "highlight_on_yank_duration": 200,
    "custom_digraphs": {}
  },
  "hover_popover_enabled": false,
  "resize_all_panels_in_dock": ["left", "right", "bottom"],
  "autosave": "on_focus_change",
  "snippet_sort_order": "top",
  "pane_split_direction_vertical": "right",
  "close_on_file_delete": true,
  "current_line_highlight": "all",
  // Determines when the mouse cursor should be hidden in an editor or input box.
  "hide_mouse": "never",
  // The default number of lines to expand excerpts in the multibuffer by.
  "expand_excerpt_lines": 4,
  "terminal": {
    "font_family": "IosevkaTerm Nerd Font Mono",
    "line_height" : "standard",
    "option_as_meta": true,
    // "vim_mode": true,
    "detect_venv": {
      "on": {
        "directories": [".env", "env", ".venv", "venv"],
        "activate_script": "default"
      }
    },
    // "font_fallbacks": ["FiraCode Nerd Fonts"],
    "toolbar": {
      "breadcrumbs": false
    }
  },
  "title_bar": {
    // Whether to show the branch icon beside branch switcher in the titlebar.
    // Whether to show the branch name button in the titlebar.
    "show_branch_status_icon": true,
    "show_branch_name": true,
    // Whether to show the project host and name in the titlebar.
    "show_project_items": true,
    // Whether to show onboarding banners in the titlebar.
    "show_onboarding_banner": true,
    // Whether to show user picture in the titlebar.
    "show_user_picture": true,
    // Whether to show the sign in button in the titlebar.
    "show_sign_in": false,
    // Whether to show the menus in the titlebar.
    "show_menus": true
  },
  "confirm_quit": true,
  "lsp": {
    "clangd": {
      "binary": {
        "path": "clangd",
        "arguments": ["--header-insertion=never"]
      }
    }
    // "pyright": {
    //   "settings": {
    //     "python.analysis": {
    //       "diagnosticMode": "workspace",
    //       "typeCheckingMode": "strict"
    //     }
    //   }
    // }
  },
  "languages": {
    "CMake": {
      "tasks": {
        "enabled": false
      }
    },
    "C++": {
      "tab_size": 2,
      // clang-format -style=google -dump-config > ~/.clang-format
      "formatter": {
        "external": {
          "command": "clang-format",
          "arguments": ["--style=file", "--assume-filename={buffer_path}"]
        }
      }
    }
  },
  "file_types": {
    "C++": ["hpp", "h", "hxx", "cpp", "cxx", "cu", "cuh", "conf", "keymap", "jinja"]
  },
  "git": {
    "inline_blame": { "enabled": false },
    "hunk_style": "unstaged_hollow"
  },
  "format_on_save": "off"
}
